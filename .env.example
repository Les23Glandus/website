# Copier en .env.local (jamais commité) et renseigner les vraies valeurs.
# Voir plan.md T002/T105 — ces valeurs dépendent de la décision d'hébergement (étape 0).

# URL de l'API Strapi (GraphQL/REST), joignable depuis le serveur Next
# uniquement (réseau interne en prod, localhost:1337 en dev — cf. "proxy"
# dans l'ancien package.json CRA). Ne sert QUE côté serveur (lib/strapi.js).
STRAPI_URL=http://localhost:1337

# URL de base des médias Strapi (dossier /uploads). Nécessaire séparément de
# STRAPI_URL car exposée aussi au navigateur (préfixe NEXT_PUBLIC_ obligatoire
# pour ça) : les <img>/antd Image affichés côté client doivent pointer
# directement sur Strapi, pas sur l'origine du site Next. En local, c'est en
# général la même valeur que STRAPI_URL (Strapi sert /uploads lui-même) ; en
# prod ça peut être un CDN devant Strapi. Voir lib/media.js.
NEXT_PUBLIC_STRAPI_MEDIA_URL=http://localhost:1337

# Jeton API Strapi si les endpoints ne sont pas publics en lecture (facultatif,
# l'ancien strapiConnector.js n'envoyait aucun Authorization header).
STRAPI_API_TOKEN=

# Origine publique du site (remplace src/class/config.js)
NEXT_PUBLIC_SITE_ORIGIN=https://www.lesglandus.fr

# Clé Google Maps — anciennement en dur dans components/meta/GoogleMaps.js.
# À régénérer/restreindre par domaine référent avant mise en prod (T111).
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Identifiant Google Analytics 4 (remplace react-ga / UA-120909023-1, mort — T701)
NEXT_PUBLIC_GA4_ID=

# Facebook App ID (repris de HtmlHead.js)
NEXT_PUBLIC_FB_APP_ID=658512374819098
